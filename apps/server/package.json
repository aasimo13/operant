{
  "name": "@operant/server",
  "version": "0.0.0",
  "private": true,
  "description": "The always-on simulation host: owns the single canonical Sim, ticks it forward continuously, applies Observer inputs, persists every step, and streams live state over WebSocket. Server-only — no React/Three.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup src/index.ts --format esm --clean"
  },
  "dependencies": {
    "@operant/core": "workspace:*",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}

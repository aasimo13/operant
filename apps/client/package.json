{
  "name": "@operant/client",
  "version": "0.0.0",
  "private": true,
  "description": "The Observer's window: a React + react-three-fiber client that renders the live Substrate and Sim and sends Providence/Intervene inputs. Rendering layer only — never owns the simulation loop.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@operant/core": "workspace:*",
    "@react-three/drei": "^10.0.1",
    "@react-three/fiber": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}

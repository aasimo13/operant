{
  "name": "operant",
  "version": "0.0.0",
  "private": true,
  "description": "One persistent reinforcement-learning Sim, shaped permanently by every Observer. Portfolio piece and art project. See CLAUDE.md and DESIGN.md.",
  "author": "Aaron Simo <https://aaronsimo.com>",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "dev:server": "pnpm --filter @operant/server dev",
    "dev:client": "pnpm --filter @operant/client dev",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}

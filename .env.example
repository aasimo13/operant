# Operant — environment variable template.
#
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored and must NEVER be committed. In production, these are
# set as Railway environment variables (server) / Vercel env vars (client).
#
# Do not put real secrets in this file — it is committed as documentation only.

# ─── Simulation host (apps/server) ───────────────────────────────────────────

# Port the always-on simulation host listens on.
PORT=8787

# Decision-tick interval in milliseconds — how often the Sim takes one
# Q-learning step. Fixed, shared infrastructure (not a per-visitor control).
# Design default is 1500ms; kept in config so it can be retuned once there is a
# real Sim to watch.
SIM_TICK_MS=1500

# Postgres connection string for the single Sim's canonical state.
# For local development against the managed Railway Postgres, use the value of
# that service's DATABASE_PUBLIC_URL (Railway dashboard → Postgres → Variables).
# In production on Railway, the server uses the private DATABASE_URL instead.
DATABASE_URL=

# Optional. Schema holding the Sim tables (default: public). Integration tests
# override this to an isolated schema so they never touch real data.
# DATABASE_SCHEMA=public

# Optional. Force TLS on/off. If unset, SSL is inferred from the host
# (off for localhost, on for remote hosts like Railway's public proxy).
# DATABASE_SSL=true

# OpenAI API key for the in-process narrator (build-order step 10).
# The narrator is a side-channel only — it never influences the Sim's actions.
OPENAI_API_KEY=

# ─── Client (apps/client) ────────────────────────────────────────────────────

# WebSocket URL the Observer's browser connects to for live Sim state.
# Vite exposes only VITE_-prefixed vars to client code.
VITE_SIM_WS_URL=ws://localhost:8787
